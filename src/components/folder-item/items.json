{
  "collectionName": "components_folder_item_items",
  "info": {
    "displayName": "Folder Item",
    "icon": "calendar",
    "description": "One item inside a desktop folder. Set 'url' to link out to a website, 'modalSlug' to open a window, or leave both empty and add Sub-Items to create a nested folder."
  },
  "options": {},
  "attributes": {
    "Title": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "icon": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "reactIcon": {
      "type": "string"
    },
    "reactIconColor": {
      "type": "string"
    },
    "modalSlug": {
      "type": "string"
    },
    "richContent": {
      "type": "richtext"
    },
    "subItem": {
      "displayName": "Sub-Items",
      "type": "component",
      "repeatable": true,
      "component": "navigation.items"
    }
  }
}
