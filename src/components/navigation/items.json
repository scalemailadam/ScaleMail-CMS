{
  "collectionName": "components_navigation_items",
  "info": {
    "displayName": "Dropdown Menu Item",
    "icon": "dashboard",
    "description": "One item in a top-bar dropdown menu or a sub-item inside a folder. Fill in 'url' to link to a website, or 'modalSlug' to open a window."
  },
  "options": {},
  "attributes": {
    "text": {
      "type": "string",
      "required": false
    },
    "url": {
      "type": "string",
      "required": false
    },
    "image": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "modalSlug": {
      "type": "string"
    },
    "contentItems": {
      "displayName": "Image Files",
      "type": "component",
      "repeatable": false,
      "component": "content.content-items"
    }
  }
}
