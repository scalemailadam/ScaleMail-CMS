{
  "collectionName": "components_navigation_dock_items",
  "info": {
    "displayName": "Dock Icon",
    "icon": "oneToOne",
    "description": "One icon in the bottom dock. Set 'url' to open a website, or 'modalSlug' to open a window (e.g. openFolder, browserModal, resumeModal, garmentDesignModal)."
  },
  "options": {},
  "attributes": {
    "reactIconName": {
      "type": "string",
      "required": false
    },
    "url": {
      "type": "string",
      "required": false
    },
    "modalSlug": {
      "type": "string",
      "required": false
    },
    "title": {
      "type": "string"
    },
    "reactIconColor": {
      "type": "string"
    },
    "icon": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
