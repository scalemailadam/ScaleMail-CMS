{
  "kind": "singleType",
  "collectionName": "headers",
  "info": {
    "singularName": "header",
    "pluralName": "headers",
    "displayName": "Header",
    "description": "The top menu bar. Contains your logo, dropdown menus, and social media icons."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "logo": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "videos",
        "audios",
        "files"
      ]
    },
    "menus": {
      "displayName": "Top Bar Menus",
      "type": "component",
      "repeatable": true,
      "component": "navigation.menu"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.social-links"
    }
  }
}
