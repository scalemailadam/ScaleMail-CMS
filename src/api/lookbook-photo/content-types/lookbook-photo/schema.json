{
  "kind": "collectionType",
  "collectionName": "lookbook_photos",
  "info": {
    "singularName": "lookbook-photo",
    "pluralName": "lookbook-photos",
    "displayName": "Lookbook — Photo",
    "description": "Photos shown in the /store/lookbook grid. Upload via Cloudinary. Use 'order' to control display sequence."
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "image": { "type": "media", "multiple": false, "required": true, "allowedTypes": ["images"] },
    "caption": { "type": "string" },
    "order": { "type": "integer", "default": 0 }
  }
}
